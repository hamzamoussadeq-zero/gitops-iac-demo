# DEV — intentionally insecure to demonstrate Checkov findings
FROM python:latest

WORKDIR /app

COPY requirements.txt .
RUN pip install -r requirements.txt

COPY . .

# Running as root (CKV_DOCKER_2)
# No HEALTHCHECK (CKV_DOCKER_10)
# Using latest tag (CKV_DOCKER_7)
# No USER instruction (CKV_DOCKER_3)

CMD ["python", "app.py"]
